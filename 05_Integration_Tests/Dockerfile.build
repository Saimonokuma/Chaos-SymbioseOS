# ══════════════════════════════════════════════════════════════════════════
# Dockerfile.build — Multi-target SymbioseOS Builder
#
# Builds 6 targets in a single container:
#   1. x86_64 BZIMAGE (Linux kernel v6.12)
#   2. hive_mind (musl static, guest PID 1)
#   3. symbiose_ircd (musl static, guest)
#   4. ChaosLoader.exe (MinGW-w64 cross-compile)
#   5. symbiose_ircd.exe (MinGW-w64 cross-compile)
#   6. initrd.img (cpio+gzip)
#
# All outputs land in /output/
# ══════════════════════════════════════════════════════════════════════════

FROM debian:bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential bc flex bison libssl-dev libelf-dev \
    cpio gzip wget file ca-certificates git \
    gcc-mingw-w64-x86-64 g++-mingw-w64-x86-64 \
    mingw-w64-tools cmake \
    musl-tools \
    rdma-core libibverbs-dev librdmacm-dev \
    liburing-dev \
    libjpeg62-turbo-dev libturbojpeg0-dev \
    libfftw3-dev \
    libnl-3-dev libnl-route-3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY . /src
WORKDIR /src
RUN mkdir -p /output

# ══════════════════════════════════════════════════════════════════════════
# BUILD 1: x86_64 Linux Kernel
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 1: Linux Kernel ===" && \
    git clone --depth=1 --branch v6.12 \
        https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git \
        /kernel-src && \
    cp 01_Chaos_Kernel/symbiose_defconfig /kernel-src/arch/x86/configs/ && \
    cd /kernel-src && \
    make ARCH=x86_64 symbiose_defconfig && \
    make ARCH=x86_64 -j$(nproc) bzImage && \
    cp arch/x86/boot/bzImage /output/BZIMAGE && \
    file /output/BZIMAGE && \
    echo "=== KERNEL BUILD COMPLETE ==="

# ══════════════════════════════════════════════════════════════════════════
# BUILD 2: hive_mind (guest PID 1, static — FULL with all 21 modules)
# Per §XVII·3: PID 1 init + 11 Multimodal + 9 OpenMOSIX modules
# Excluded: bpf_gpu_monitor.bpf.c (BPF runtime), moviola_dvs.c (P3 libcaer)
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 2: hive_mind (FULL — 21 modules + glue) ===" && \
    MM_DIR=/src/03_HiveMind_Orchestrator/ChaosLoader/src && \
    MX_DIR=/src/03_HiveMind_Orchestrator/openmosix_nx/src && \
    gcc -static -Os -D__linux__ \
        -I${MM_DIR} \
        -I/src/02_Symbiose_Bridge/inc \
        -I${MX_DIR} \
        -Wall -Wno-unused-function \
        -o /output/hive_mind \
        ${MM_DIR}/hive_mind_init.c \
        ${MM_DIR}/hive_mind_glue.c \
        ${MM_DIR}/modality_router.c \
        ${MM_DIR}/vision_pipeline.c \
        ${MM_DIR}/tts_pipeline.c \
        ${MM_DIR}/moviola_delta.c \
        ${MM_DIR}/moviola_dibit.c \
        ${MM_DIR}/video_temporal.c \
        ${MM_DIR}/scout_modality.c \
        ${MM_DIR}/modality_hotswap.c \
        ${MM_DIR}/demhx_midi_grammar.c \
        ${MM_DIR}/demhx_rdi.c \
        ${MX_DIR}/migrate.c \
        ${MX_DIR}/node_score.c \
        ${MX_DIR}/rdma_pool.c \
        ${MX_DIR}/rdma_stream.c \
        ${MX_DIR}/tensor_alloc.c \
        ${MX_DIR}/tensor_io.c \
        ${MX_DIR}/kv_shard_mgr.c \
        ${MX_DIR}/criugpu_daemon.c \
        ${MX_DIR}/rebalance_harmonic.c \
        -lm -lpthread -lrdmacm -libverbs -lnl-route-3 -lnl-3 -luring -lturbojpeg -lfftw3 && \
    file /output/hive_mind && \
    SIZE=$(stat -c%s /output/hive_mind) && \
    echo "=== hive_mind FULL BUILD COMPLETE: $SIZE bytes ==="

# ══════════════════════════════════════════════════════════════════════════
# BUILD 3: symbiose_ircd (guest, musl static)
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 3: symbiose_ircd (guest) ===" && \
    musl-gcc -static -O2 \
        -o /output/symbiose_ircd \
        /src/03_HiveMind_Orchestrator/IRCd_Neural_Bus/src/ircd_guest_main.c && \
    file /output/symbiose_ircd && \
    echo "=== symbiose_ircd (guest) BUILD COMPLETE ==="

# ══════════════════════════════════════════════════════════════════════════
# BUILD 4: ChaosLoader.exe (MinGW-w64 cross-compile)
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 4: ChaosLoader.exe ===" && \
    cd /src/03_HiveMind_Orchestrator/ChaosLoader/src && \
    wget -q https://raw.githubusercontent.com/DaveGamble/cJSON/v1.7.18/cJSON.c && \
    wget -q https://raw.githubusercontent.com/DaveGamble/cJSON/v1.7.18/cJSON.h && \
    x86_64-w64-mingw32-gcc -O2 -DUNICODE -D_UNICODE -D_WIN32_WINNT=0x0A00 \
        -I. -I/src/02_Symbiose_Bridge/inc/ \
        main.c kernel_ioctls.c boot_params.c cJSON.c \
        -o /output/ChaosLoader.exe \
        -lsetupapi -lws2_32 && \
    file /output/ChaosLoader.exe && \
    echo "=== ChaosLoader.exe BUILD COMPLETE ==="

# ══════════════════════════════════════════════════════════════════════════
# BUILD 5: symbiose_ircd.exe (Win32 cross-compile)
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 5: symbiose_ircd.exe ===" && \
    cd /src/03_HiveMind_Orchestrator/IRCd_Neural_Bus/src && \
    x86_64-w64-mingw32-gcc -O2 -D_WIN32_WINNT=0x0A00 \
        -I. \
        symbiose_ircd.c ctcp_dcc.c dcc_tensor.c shm_ring.c \
        xdcc_bot.c tensor_index.c irc_qos.c jumbo_payload.c \
        -o /output/symbiose_ircd.exe \
        -lws2_32 && \
    file /output/symbiose_ircd.exe && \
    echo "=== symbiose_ircd.exe BUILD COMPLETE ==="

# ══════════════════════════════════════════════════════════════════════════
# BUILD 6: initrd.img (cpio + gzip) — per §XVII·1
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BUILD 6: initrd.img (§XVII·1 compliant) ===" && \
    mkdir -p /initrd/sbin /initrd/usr/bin /initrd/proc /initrd/sys \
            /initrd/dev /initrd/etc/symbiose /initrd/tmp /initrd/lib && \
    cp /output/hive_mind /initrd/sbin/hive_mind && \
    cp /output/symbiose_ircd /initrd/sbin/symbiose_ircd && \
    chmod +x /initrd/sbin/* && \
    ln -sf /sbin/hive_mind /initrd/init && \
    echo '{"model_path":"","format":"SafeTensors","multimodal":false,"port":8080}' \
        > /initrd/etc/symbiose/model.conf && \
    echo '{"node_id":"00000000-0000-0000-0000-000000000000","vram_gb":0,"rdma_capable":false}' \
        > /initrd/etc/symbiose/node.conf && \
    cd /initrd && \
    find . | cpio -o -H newc 2>/dev/null | gzip -9 > /output/initrd.img && \
    SIZE=$(stat -c%s /output/initrd.img) && \
    echo "Contents:" && \
    gzip -dc /output/initrd.img | cpio -t 2>/dev/null && \
    echo "=== initrd.img BUILD COMPLETE: $SIZE bytes ==="

# ══════════════════════════════════════════════════════════════════════════
# VERIFY: All modules are now LINKED in BUILD 2 (not just syntax-checked)
# This step validates the output binaries
# ══════════════════════════════════════════════════════════════════════════
RUN echo "=== BINARY VERIFICATION ===" && \
    echo "" && \
    echo "  hive_mind: $(stat -c%s /output/hive_mind) bytes" && \
    echo "  symbiose_ircd: $(stat -c%s /output/symbiose_ircd) bytes" && \
    echo "  ChaosLoader.exe: $(stat -c%s /output/ChaosLoader.exe) bytes" && \
    echo "  symbiose_ircd.exe: $(stat -c%s /output/symbiose_ircd.exe) bytes" && \
    echo "  BZIMAGE: $(stat -c%s /output/BZIMAGE) bytes" && \
    echo "  initrd.img: $(stat -c%s /output/initrd.img) bytes" && \
    echo "" && \
    echo "── hive_mind module strings ──" && \
    strings /output/hive_mind | grep -E 'modality|moviola|tensor|rdma|hive_mind|Step [0-9]' | head -20 && \
    echo "" && \
    echo "══════════════════════════════════════════════════════════" && \
    echo "  All 6 targets built and verified" && \
    echo "══════════════════════════════════════════════════════════"

# ── Final verification ───────────────────────────────────────────────────
RUN echo "" && \
    echo "══════════════════════════════════════════════════════════" && \
    echo "  SymbioseOS Build Complete" && \
    echo "══════════════════════════════════════════════════════════" && \
    ls -lh /output/ && \
    echo "" && \
    file /output/* && \
    echo "══════════════════════════════════════════════════════════"

CMD ["echo", "Build complete. Use: docker cp symbiose-build:/output/. ./build/"]
